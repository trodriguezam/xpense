      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the action's Amount (CLP) field.\n\nIn the bar above the keyboard, swipe sideways until you find the Shortcut Input variable and tap it.\n\nThen tap that same variable (the blue token) again and choose Amount."
          }
        }
      }
